# Copy this file to .env and fill in your API key
# Get your key from: https://console.anthropic.com or https://platform.openai.com

# Option 1: Use Anthropic Claude (recommended)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option 2: Use OpenAI GPT-4
OPENAI_API_KEY=your_openai_api_key_here

# Which LLM to use: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# App settings
APP_TITLE=EI-RCA: Engineering Intelligence Twin
DEBUG=false
